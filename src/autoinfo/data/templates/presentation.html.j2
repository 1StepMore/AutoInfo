<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>{{ title }}</title>

{# Reveal.js CSS from CDN — never bundled #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/reveal.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/theme/{{ theme|default('black') }}.css" id="reveal-theme">

{# Plugin: speaker notes (required for <aside class="notes">) #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5/plugin/notes/notes.css">

<style>
  /* AutoInfo presentation overrides — kept minimal, theme-aware */
  .reveal .slides section.cover-slide {
    text-align: center;
  }
  .reveal .slides section.cover-slide h1 {
    font-size: 1.8em;
    margin-bottom: 0.4em;
  }
  .reveal .slides section.cover-slide .meta {
    font-size: 0.55em;
    opacity: 0.75;
    margin-top: 1em;
  }
  .reveal .slides section .slide-content {
    text-align: left;
    font-size: 0.85em;
    line-height: 1.4;
    margin-top: 0.5em;
  }
  .reveal .slides section .slide-bullets {
    margin-top: 0.5em;
    text-align: left;
  }
  .reveal .slides section .slide-bullets li {
    margin-bottom: 0.3em;
  }
  .reveal .slides section .speaker-notes-hint {
    display: none;
  }
  .reveal .footer-autoinfo {
    font-size: 0.4em;
    opacity: 0.5;
    position: fixed;
    bottom: 0.5em;
    right: 1em;
  }
</style>
</head>
<body>

<div class="reveal">
  <div class="slides">

    {# Cover slide #}
    <section class="cover-slide">
      <h1>{{ title }}</h1>
      {% if description %}
      <p class="meta">{{ description }}</p>
      {% endif %}
      <p class="meta">
        {% if topic %}Topic: {{ topic }} &middot; {% endif %}
        {% if domain %}Domain: {{ domain }} &middot; {% endif %}
        Audience: {{ target_audience }} &middot; Slides: {{ slides|length }}
      </p>
    </section>

    {# Content slides #}
    {% for slide in slides %}
    <section>
      <h2>{{ slide.title }}</h2>
      {% if slide.content %}
      <div class="slide-content">{{ slide.content }}</div>
      {% endif %}
      {% if slide.bullets %}
      <ul class="slide-bullets">
        {% for bullet in slide.bullets %}
        <li>{{ bullet }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if slide.notes %}
      <aside class="notes">{{ slide.notes }}</aside>
      {% endif %}
    </section>
    {% endfor %}

    {# Closing slide #}
    <section class="cover-slide">
      <h1>Thank You</h1>
      <p class="meta">
        Generated by AutoInfo &middot; {{ domain }} &middot; {{ generated_at }}
      </p>
    </section>

  </div>
</div>

{# Reveal.js JS from CDN — never bundled #}
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/reveal.js"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5/plugin/notes/notes.js"></script>

<script>
  Reveal.initialize({
    transition: '{{ transition|default("slide") }}',
    controls: true,
    progress: true,
    center: true,
    hash: true,
    slideNumber: 'c/t',
    plugins: [RevealNotes]
  });
</script>

</body>
</html>